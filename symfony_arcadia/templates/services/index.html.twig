{% extends 'base.html.twig' %}

{% block title %}Services{% endblock %}

{% block style %}url('img/servicesBackground.jpg'){% endblock style %}

{% block content %}

    <section class= "servicesPages">
        <h1 class=" text-center servcicesPageTitle">Nos services présent dans le zoo</h1>
        <div class='allEle'>
            {% for service in allServices %}
                <div class="grid-ele service1">
                    <h3>{{service.name}}</h3>
                    <div class="description_img">
                        <p>{{service.description}}</p>
                        <img class="serviceImg" src="img/{{service.img}}.jpg" width="275px" height="250px">
                    </div>
                </div>
            {% endfor %}
        </div>
        
    </section>

{% endblock %}
