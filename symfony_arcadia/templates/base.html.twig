<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {% block stylesheets %}
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.3.1/dist/css/bootstrap.min.css" integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T" crossorigin="anonymous">
            <link rel="stylesheet" href="../../styles/app.css">
        {% endblock stylesheets %}

        

    </head>
    <body>
        <style>
            body{
                position:relative;
                background-color:rgb(138,226,107);
                z-index:-5;
            }

            body:after{
                content : "";
                z-index : -1;
                position : absolute;
                top : 0; left : 0; right : 0; bottom : 0;
                background-image:{% block style %}{% endblock style %};
                background-repeat: no-repeat;
                background-size:cover;
                height:100%;
                opacity: 0.7;
                
            }
            
        </style>
        
        {% block body %}
            <div class="navbar">
                <img src="../../img/logo.png" width="56px" height="53" class="logo">
                <h3 class='zoo_name'> arcadia zoo </h3>
                <div class="link">
                    <div class="link-navbar"><a href="/"> accuil</a></div>
                    <div class="link-navbar"><a href="/services"> services</a></div>
                    <div class="link-navbar"><a href="/habitats">habitats</a></div>
                    {% if is_granted('ROLE_VETERINAIRE') or is_granted("ROLE_EMPLOYER") %}
                        <div class="link-navbar"><a href="/logout">déconnection</a></div>
                    {% else %}
                        <div class="link-navbar"><a href="/login">connection</a></div>
                    {% endif %}
...                 {% if not(is_granted("ROLE_VETERINAIRE"))or not(is_granted("ROLE_EMPLOYER")) %} 
                        <div class="link-navbar"><a href='/message_zoo'>contact</a></div>
                    {% endif %}
                    {% if is_granted("ROLE_ADMINISTRATION") %}
                        <div class="link-navbar"><a href='/administration'> espace administration</a></div>
                    {% endif %}
                    {% if (is_granted("ROLE_VETERINAIRE") or is_granted("ROLE_EMPLOYER" ))and not(is_granted("ROLE_ADMINISTRATION")) %}
                         <div class="link-navbar"><a href='#'> espace presonnelle</a></div>
                    {% endif %}
                </div>
            </div>
        {% endblock body %}
        {% block content %}{% endblock content %}
        {% block footer %}
            <div class="footer">
                <p> pppppppp</p>
            </div>
        {% endblock footer %}
    </body>
</html>
